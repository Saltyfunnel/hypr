  },
  "custom/updates": {
    "exec": "count=$(checkupdates 2>/dev/null | wc -l); aur=$(yay -Qua 2>/dev/null | wc -l); total=$((count + aur)); [ $total -gt 0 ] && echo \"ůįöį $total\" || echo ''",
    "return-type": "",
    "format": "{}",
    "interval": 3600,
    "on-click": "kitty -- yay",
    "tooltip": true,
    "tooltip-format": "ůįöį Updates available\n\n click  run yay"
  },
  "custom/screenshot": {
    "format": "ůįĻĎ",
    "on-click": "~/.config/scripts/screenshot.sh area",
    "on-click-middle": "~/.config/scripts/screenshot.sh window",
    "on-click-right": "~/.config/scripts/screenshot.sh screen",
    "tooltip": true,
    "tooltip-format": "ůįĻĎ Screenshot\n\n click  area selection\n middle  active window\n right  fullscreen"
  },
  "custom/spotify": {
    "exec": "playerctl -p spotify metadata --format 'ůįďá {{ artist }} - {{ title }}' 2>/dev/null || echo ''",
    "exec-if": "playerctl -p spotify status 2>/dev/null | grep -q 'Playing\\|Paused'",
    "return-type": "",
    "format": "{}",
    "interval": 3,
    "on-click": "playerctl -p spotify play-pause",
    "tooltip": true,
    "tooltip-format": "ůįďá Spotify\n\n click  play / pause",
    "max-length": 25
  },
  "custom/firefox": {
    "exec": "pgrep -x firefox >/dev/null && echo 'ůįąĻ' || echo ''",
    "return-type": "",
    "format": "{}",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "ůįąĻ Firefox is running"
  },
  "custom/steam": {
    "exec": "pgrep -x steam >/dev/null && echo 'ůįďď' || echo ''",
    "return-type": "",
    "format": "{}",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "ůįďď Steam is running"
  },
  "custom/power": {
    "format": "‚ŹĽ",
