{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "spacing": 4,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "group/right-pill"
  ],
  "group/right-pill": {
    "orientation": "horizontal",
    "modules": [
      "custom/spotify",
      "custom/firefox",
      "custom/steam",
      "group/sys-drawer"
    ]
  },
  "group/sys-drawer": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "drawer-child",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/menu-icon",
      "memory",
      "cpu",
      "temperature",
      "temperature#gpu",
      "battery",
      "backlight",
      "pulseaudio",
      "pulseaudio#microphone",
      "network",
      "bluetooth",
      "custom/screenshot",
      "custom/power"
    ]
  },
  "custom/menu-icon": {
    "format": "󰀻",
    "tooltip": true,
    "tooltip-format": "Click to open App Launcher",
    "on-click": "python3 ~/.config/scripts/app.py"
  },
  "memory": {
    "format": "󰾆 {used}GB",
    "on-click": "kitty -- btop",
    "tooltip": true,
    "tooltip-format": "Left Click: Open btop\nRAM: {used:0.1f}GiB / {total:0.1f}GiB"
  },
  "cpu": {
    "format": " {usage}%",
    "on-click": "kitty -- btop",
    "tooltip": true,
    "tooltip-format": "Left Click: Open btop\nUsage: {usage}%"
  },
  "custom/screenshot": {
    "format": "󰄀 ",
    "on-click": "~/.config/scripts/screenshot.sh area",
    "on-click-middle": "~/.config/scripts/screenshot.sh window",
    "on-click-right": "~/.config/scripts/screenshot.sh screen",
    "tooltip": true,
    "tooltip-format": "Left: Area\nMiddle: Window\nRight: Fullscreen"
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "systemctl poweroff",
    "on-click-middle": "hyprctl dispatch exit",
    "on-click-right": "systemctl reboot",
    "tooltip": true,
    "tooltip-format": "Left: Shutdown\nMiddle: Log Out\nRight: Reboot"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟",
    "format-icons": {
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "on-click": "pavucontrol",
    "tooltip": true,
    "tooltip-format": "{icon} {volume}% - {desc}"
  },
"network": {
  "format-wifi": "󰤨 {essid}",
  "format-ethernet": "󰈀",
  "interval": 2,
  "tooltip": true,
  "tooltip-format": "IP: {ipaddr}\nSSID: {essid}\nStrength: {signaldBm}dBm",
  "on-click": "kitty -- nmtui"
},
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": 3
    }
  },
  "hyprland/window": {
    "format": "󰣇  {}"
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip": true,
    "tooltip-format": "{:%A, %B %d, %Y}"
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
    "format": "󰔏 {temperatureC}°C"
  },
  "temperature#gpu": {
    "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "format": "󰘚 {temperatureC}°C"
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": [
      "󰂃",
      "󰁺",
      "󰁻",
      "󰁼",
      "󰁽",
      "󰁾",
      "󰁿",
      "󰂀",
      "󰂁",
      "󰂂",
      "󰁹"
    ]
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "󰃞",
      "󰃟",
      "󰃠"
    ]
  },
 "bluetooth": {
  "format": "󰂯",
  "format-connected": "󰂱",
  "format-disabled": "󰂲",
  "format-off": "󰂲",
  "on-click": "blueman-manager",
  "tooltip": true,
  "tooltip-format": "Bluetooth: {status}",
  "tooltip-format-connected": "{device_alias}",
  "tooltip-format-connected-battery": "{device_alias} — {device_battery_percentage}%"
},
  "pulseaudio#microphone": {
    "format": "󰍬 {volume}%",
    "on-click": "pamixer --default-source -t"
  },
  "custom/spotify": {
    "exec": "playerctl -p spotify metadata --format '󰓇 {{ artist }} - {{ title }}' 2>/dev/null || echo ''",
    "exec-if": "playerctl -p spotify status 2>/dev/null | grep -q 'Playing\\|Paused'",
    "return-type": "",
    "format": "{}",
    "interval": 3,
    "on-click": "playerctl -p spotify play-pause",
    "max-length": 25
  },
  "custom/firefox": {
    "exec": "pgrep -x firefox >/dev/null && echo '󰈹' || echo ''",
    "return-type": "",
    "format": "{}",
    "interval": 5
  },
  "custom/steam": {
    "exec": "pgrep -x steam >/dev/null && echo '󰓓' || echo ''",
    "return-type": "",
    "format": "{}",
    "interval": 5
  }
}
