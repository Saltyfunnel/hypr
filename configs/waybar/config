{
  "layer": "top",
  "position": "top",
  "spacing": 4,

  "modules-left": [
    "custom/firefox",
    "custom/steam",
    "hyprland/workspaces",
    "hyprland/window"
  ],

  "modules-center": [
    "clock",
    "custom/spotify"
  ],

  "modules-right": [
    "custom/updates",
    "custom/system",
    "battery",
    "backlight",
    "pulseaudio",
    "network",
    "bluetooth",
    "tray",
    "custom/screenshot",
    "custom/power"
  ],

  "custom/system": {
    "exec": "~/.config/waybar/scripts/system-info.sh",
    "interval": 5,
    "return-type": "json",
    "on-click": "kitty -- btop"
  },

  "custom/updates": {
    "exec": "count=$(checkupdates 2>/dev/null | wc -l); aur=$(yay -Qua 2>/dev/null | wc -l); total=$((count + aur)); [ \"$total\" -gt 0 ] && echo \"¾░Ü░ $total\" || echo ''",
    "interval": 1800,
    "on-click": "kitty -- yay",
    "tooltip": true,
    "tooltip-format": "¾░Ü░ Updates available\n\n click  run yay"
  },

  "custom/spotify": {
    "exec": "playerctl metadata --format '¾░ôç {{ artist }} - {{ title }}' 2>/dev/null",
    "exec-if": "playerctl status 2>/dev/null",
    "interval": 5,
    "on-click": "playerctl play-pause",
    "max-length": 30
  },

  "custom/firefox": {
  "exec": "pgrep -x firefox >/dev/null && echo '¾░ê╣'",
  "interval": 10,
  "format": "{}",
  "tooltip": false
},

"custom/steam": {
  "exec": "pgrep -x steam >/dev/null && echo '¾░ôô'",
  "interval": 10,
  "format": "{}",
  "tooltip": false
},

  "custom/screenshot": {
    "format": "¾░╣æ",
    "on-click": "~/.config/scripts/screenshot.sh area",
    "on-click-middle": "~/.config/scripts/screenshot.sh window",
    "on-click-right": "~/.config/scripts/screenshot.sh screen",
    "tooltip": true,
    "tooltip-format": "¾░╣æ Screenshot\n\n click  area\n middle  window\n right  screen"
  },

  "custom/power": {
    "format": "ÔÅ╗",
    "on-click": "systemctl poweroff",
    "on-click-middle": "hyprctl dispatch exit",
    "on-click-right": "systemctl reboot",
    "tooltip": true,
    "tooltip-format": "ÔÅ╗ Power\n\n click  shutdown\n middle  logout\n right  reboot"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "¾░Øƒ",
    "format-icons": {
      "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
    },
    "on-click": "pavucontrol",
    "tooltip-format": "Volume: {volume}%\n{desc}"
  },

  "network": {
    "format-wifi": "¾░ñ¿",
    "format-ethernet": "¾░êÇ",
    "format-disconnected": "¾░ñ¡",
    "interval": 5,
    "on-click": "kitty -- nmtui",
    "tooltip-format-wifi": "{essid}\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}"
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": 3
    }
  },

  "hyprland/window": {
    "format": "¾░úç  {}",
    "max-length": 50
  },

  "clock": {
    "format": "´Çù {:%H:%M}",
    "tooltip-format": "{:%A, %B %d, %Y}\nweek {:%V}"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "¾░éä",
    "format-plugged": "¾▒Éï",
    "tooltip-format": "{capacity}%"
  },

  "backlight": {
    "format": "{icon}",
    "format-icons": ["¾░â×","¾░âƒ","¾░âá"],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "bluetooth": {
    "format": "¾░é»",
    "format-connected": "¾░é▒",
    "format-off": "¾░é▓",
    "on-click": "blueman-manager",
    "tooltip-format": "{status}"
  },

  "tray": {
    "spacing": 6
  }
}
