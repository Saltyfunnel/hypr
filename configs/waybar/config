{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "spacing": 2,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/updates",
    "custom/spotify",
    "custom/firefox",
    "custom/steam",
    "memory",
    "cpu",
    "temperature",
    "temperature#gpu",
    "battery",
    "backlight",
    "pulseaudio",
    "pulseaudio#microphone",
    "network",
    "bluetooth",
    "custom/screenshot",
    "custom/power"
  ],
  "cpu": {
    "format": "Ôíľ {usage}%",
    "on-click": "kitty -- btop",
    "tooltip": true,
    "tooltip-format": "ůįĽ† CPU Usage: {usage}%\nůįŹó Cores: {core0}% {core1}% {core2}% {core3}%\n\n click  open btop"
  },
  "memory": {
    "format": "ÓŅÖ {used}GB",
    "on-click": "kitty -- btop",
